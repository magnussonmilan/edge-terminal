VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# The Odds API (https://the-odds-api.com/) — optional. Put the real key in .env (gitignored), not here.
# Licensed multi-book odds for apps/dashboards (see their ToS: no reselling the raw feed).
# Line shopping (/lines) uses ~3 credits/poll (h2h+spreads+totals × ~10 bookmakers).
# Scripts / GitHub Actions: ODDS_API_KEY=...
# Local Vite live fetch (dev only): VITE_ODDS_API_KEY=...
# ODDS_API_KEY=
# VITE_ODDS_API_KEY=
